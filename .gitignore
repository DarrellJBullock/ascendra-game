# OS
.DS_Store

# Env / secrets (never commit real keys; .env.example is tracked)
.env
**/.env
!**/.env.example

# Node / Next (also covered by frontend/.gitignore)
**/node_modules/
**/.next/
**/out/
**/coverage/

# Python (also covered by backend/.gitignore)
**/.venv/
**/__pycache__/
**/*.pyc
.pytest_cache/
