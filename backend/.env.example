# Set to a real OpenAI key to enable real event generation. When unset, the
# service auto-falls-back to the schema-valid stub response (safe for local
# dev with no key required).
OPENAI_API_KEY=

# Cheap/fast tier model for narrative flavor text.
OPENAI_MODEL=gpt-4o-mini

# Server-side timeout (seconds) on the OpenAI call, kept under the client's
# 5s hard abort so a slow upstream fails clean with a structured error.
OPENAI_TIMEOUT_SECONDS=4.0

# Comma-separated origins allowed to call this API (local frontend dev server, etc).
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Per-IP rate limit (requests/minute) on the billed /v1/events/generate endpoint.
# A full playthrough is only ~4-10 calls over minutes of play, so 30/min/IP is
# ample for a real player while capping a runaway script. In-memory/per-process;
# for a multi-instance deploy use an edge/CDN rate limit instead.
RATE_LIMIT_PER_MINUTE=30

# Max accepted request body size in bytes. The real payload is well under 1 KB;
# 8 KB is generous headroom while rejecting oversized/garbage bodies early.
MAX_REQUEST_BODY_BYTES=8192

# Optional override: "true" forces the stub path, "false" forces the real
# OpenAI call path regardless of whether a key is set. Leave unset for the
# default "auto" behavior (stub only when no OPENAI_API_KEY is configured).
USE_STUB=
