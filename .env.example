# Ascendra v1 — root env for docker-compose full-stack run.
# Copy to .env (gitignored) and fill in before `docker compose up`.

# --- Backend (AI Event Proxy) ---

# The ONLY real secret this project has. Leave blank to run entirely on the
# built-in schema-valid stub response (no Anthropic account needed for local
# dev/demo/smoke-testing).
ANTHROPIC_API_KEY=

# Claude model. Default claude-sonnet-5; claude-haiku-4-5 (cheapest) or
# claude-opus-4-8 (richest) also valid.
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_TIMEOUT_SECONDS=4.0

# Comma-separated list of origins allowed to call the backend. Must match
# wherever the frontend is actually served from (browser Origin header).
# Local compose default matches the frontend service's published port.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Force stub ("true") or force real-call ("false"). Leave blank for auto
# (stub only when ANTHROPIC_API_KEY is unset).
USE_STUB=

# --- Frontend (Next.js) ---

# Base URL the BROWSER uses to reach the backend. Baked in at build time
# (Next.js NEXT_PUBLIC_* vars are compiled into the client bundle), so this
# must be set before `docker compose build`, not just before `up`, and must
# be the backend's public/host-reachable URL, not an internal Docker
# service name. Local compose default: the backend's published port.
NEXT_PUBLIC_AI_PROXY_URL=http://localhost:8000
